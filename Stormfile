// Stormfile, autogenerated by sk init
cc: /usr/bin/gcc
cflags: -Wall -Wextra -Werror -std=c23
lflags:
defines: -DDEBUG

build_type: debug

target talos
{
    print: __sk_version__
    out: talos
    kind: exec

    if(build_type == debug){
        cflags::  -g
        defines:: -DDEBUG
    }
    else
    {
        cflags::  -O2
        defines:: -DNDEBUG
    }

    if(__os__ == "linux")
    {
        exclude:
            external/vx/src/macos/
            external/vx/src/win32/
    }

    sources:
        src/
        external/vx/src/
    includes:
        -Isrc
        -Isrc/core
        -Isrc/memory
        -Iexternal/vx/include

    install: ~/.local/bin
}
