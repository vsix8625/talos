cc: /usr/bin/gcc
cflags: -Wall -Wextra -Werror -std=c23 -pthread

major: 0
minor: 11
patch: 0

if(__sk_version_minor__ < 8)
{
    exit: "Requires sk version 0.8.x or latest"
}

codegen src/core/config.h
{
    literal: "#pragma once"

    define: TALOS_VERSION_MAJOR major
    define: TALOS_VERSION_MINOR minor
    define: TALOS_VERSION_PATCH patch
    define: TALOS_VERSION_STRING "major.minor.patch"
}

target imgui
{
    out: imgui
    kind: static
    cc: /usr/bin/clang++
    mode: release

    cflags: -std=c++17 -O3 -fno-exceptions -fno-rtti -fno-threadsafe-statics -ffast-math -march=x86-64
    defines:: -DIMGUI_IMPL_OPENGL_LOADER_GLAD

    sources:
        external/imgui/
    includes:
        -Iexternal/imgui/include
        -Iexternal/imgui
        -Iexternal/imgui/backends

}

target gui
{
    out: gui
    kind: static
    cc: /usr/bin/g++
    depends: imgui
    cflags: -std=c++23 -Wall -Werror -Wextra

    if(talos_debug)
    {
        mode: debug
        cflags::
            -g
        defines::
            -DDEBUG
    }
    else
    {
        mode: release
        cflags::
            -O3
            -march=x86-64
        defines::
            -DNDEBUG

    }


    defines::
        -DIMGUI_IMPL_OPENGL_LOADER_GLAD

    sources:
        src/gui/talos_gui.cpp
    includes:
        -Isrc/gui
        -Iexternal/include
        -Iexternal/imgui/include
        -Iexternal/imgui
        -Iexternal/imgui/backends
}

target talos_fanctl
{
    kind: exec
    mode: release

    cflags:
        -std=c17
        -O2
        -march=x86-64
    defines:
        -DNDEBUG

    sources:
        tools/talos-fanctl/talos-fanctl.c

}

target talos_power
{
    kind: exec
    mode: release

    cflags:
        -std=c17
        -O2
        -march=x86-64
    defines:
        -DNDEBUG

    sources:
        tools/talos-power/talos-power.c
}

target talos
{
    linker: mold
    print: __sk_version__
    out: talos
    kind: exec
    depends:
        gui
        imgui
        talos_fanctl
        talos_power


    lflags:
        -lSDL3
        -lm
        -pthread
        -lfontconfig

    if(talos_debug)
    {
        out: talos-debug
        mode: debug
        cflags::  -g
        defines:: -DDEBUG
    }
    else
    {
        mode: release
        cflags::
            -O3
            -march=x86-64
            -mbmi
        defines:: -DNDEBUG

    }

    rpath: $ORIGIN // sets -Wl,-rpath,$ORIGIN

    // copies files to target bin dir
    deploy:
        /usr/local/lib/libSDL3.so.0
        assets/fonts/JetBrainsMonoNerdFont-Medium.ttf

    if(__os__ == "linux")
    {
        exclude:
            external/vx/src/macos/
            external/vx/src/win32/
    }


    if(rel)
    {
        cflags::
            -flto
            -ffunction-sections
            -fdata-sections
        lflags::
            -flto
            -Wl,--gc-sections
            -Wl,-O1
    }

    exclude::
        src/gui/
    sources:
        src/
        external/vx/src/
    includes:
        -Isrc
        -Isrc/core
        -Isrc/memory
        -Isrc/sdl3
        -Isrc/gl
        -Iexternal/include
        -Iexternal/vx/include

    install: ~/.local/bin
}
