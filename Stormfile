// Stormfile, autogenerated by sk init
cc: /usr/bin/gcc
cflags: -Wall -Wextra -Werror -std=c23 -pthread


build_type: debug

target imgui
{
    out: imgui
    kind: static
    cc: /usr/bin/clang++

    cflags: -std=c++17 -O2 -fno-exceptions -fno-rtti -fno-threadsafe-statics -ffast-math -march=native
    defines:: -DIMGUI_IMPL_OPENGL_LOADER_GLAD

    sources:
        external/imgui/
    includes:
        -Iexternal/imgui/include
        -Iexternal/imgui
        -Iexternal/imgui/backends

}

target gui
{
    out: gui
    kind: static
    cc: /usr/bin/g++

    cflags: -std=c++23 -Wall -Werror -Wextra -g
    depends: imgui

    defines::
        -DDEBUG
        -DIMGUI_IMPL_OPENGL_LOADER_GLAD

    sources:
        src/gui/talos_gui.cpp
    includes:
        -Isrc/gui
        -Iexternal/include
        -Iexternal/imgui/include
        -Iexternal/imgui
        -Iexternal/imgui/backends
}

target talos
{
    linker: mold
    print: __sk_version__
    out: talos
    kind: exec

    lflags:
        -lSDL3
        -lm
        -pthread

    if(build_type == debug){
        cflags::  -g
        defines:: -DDEBUG
    }
    else
    {
        cflags::  -O2
        defines:: -DNDEBUG
    }

    if(__os__ == "linux")
    {
        exclude:
            external/vx/src/macos/
            external/vx/src/win32/
    }

    depends:
        imgui
        gui

    exclude::
        src/gui/
    sources:
        src/
        external/vx/src/
    includes:
        -Isrc
        -Isrc/core
        -Isrc/memory
        -Isrc/sdl3
        -Isrc/gl
        -Iexternal/include
        -Iexternal/vx/include

    install: ~/.local/bin
}
